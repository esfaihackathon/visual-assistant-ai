<?xml version="1.0" encoding="utf-8"?>
<!--
    Saral logo: bank building (finance) + amber sound waves (voice / accessibility).
    Visible against the dark navy adaptive-icon background (#0A1628).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <group
        android:pivotX="54"
        android:pivotY="54">

        <!-- Bank roof — triangle -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M54,18 L84,42 L24,42 Z"/>

        <!-- Ledge beneath roof -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M22,42 L86,42 L86,47 L22,47 Z"/>

