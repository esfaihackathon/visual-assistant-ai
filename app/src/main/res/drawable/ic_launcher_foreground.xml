        <path
            android:fillColor="#FFFFFF"
            android:pathData="M49,47 L59,47 L59,73 L49,73 Z"/>

        <!-- Right column -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M68,47 L78,47 L78,73 L68,73 Z"/>

        <!-- Base platform -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M21,73 L87,73 L87,79 L21,79 Z"/>

